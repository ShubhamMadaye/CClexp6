s{% extends "layout.njk" %}

{% block title %}Home Page{% endblock %}

{% block content %}
    <main class="flex-shrink-0">
        <div class="container">
            <h1 class="mt-5">Add a New Note</h1>
            <p class="lead mt-2 mb-4">Write down your thought, idea, or learning.</p>
            <hr>
            <div class="row justify-content-center">
                <div class="col-12 col-md-8">
                    <div class="form-card">
                        <form method="post" action="/save">
                            <label for="content" style="color:#a78bfa; font-weight:600; margin-bottom:0.5rem; display:block;">✏️ Your Note</label>
                            <textarea id="content" name="content" class="form-control" rows="10" placeholder="Write anything..."></textarea>
                            {% if error.length > 0  %}
                                <div class="flash-error mt-2">
                                    ⚠️ {{ error }} 
                                </div>
                            {% endif %}
                            <div style="display:flex; gap:1rem; margin-top:1rem;">
                                <a href="/" class="btn" style="background:rgba(255,255,255,0.08); color:#f8fafc; border-radius:50px; padding:0.6rem 1.4rem; flex:1; text-align:center; border:1px solid rgba(255,255,255,0.1);">Cancel</a>
                                <button class="btn btn-primary" style="flex:2; border-radius:50px !important;">💾 Save Note</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
